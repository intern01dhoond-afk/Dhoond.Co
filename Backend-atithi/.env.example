# Backend Environment Variables — EXAMPLE FILE
# Copy this to .env and fill in real values. NEVER commit .env to git.

PORT=5001

# PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dhoond

# Razorpay (use rzp_live_* keys in production)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# BulkSMS OTP
BULKSMS_AUTH_KEY=your_bulksms_auth_key
BULKSMS_SENDER=DHOOND
BULKSMS_ROUTE=2
BULKSMS_DLT_TE_ID=your_dlt_template_id

# CORS — comma-separated list of allowed frontend origins
# Leave empty in development (localhost is allowed automatically)
# Example: ALLOWED_ORIGINS=https://dhoond.co,https://www.dhoond.co
ALLOWED_ORIGINS=
