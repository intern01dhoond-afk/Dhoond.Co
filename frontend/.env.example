# Frontend Environment Variables — EXAMPLE FILE
# Copy this to .env and fill in real values. NEVER commit .env to git.

# Your backend API URL — set to your deployed backend in production
VITE_API_URL=http://localhost:5001

# Google Maps (restrict this key to your domain in Google Cloud Console)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Razorpay (use rzp_live_* key in production)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
